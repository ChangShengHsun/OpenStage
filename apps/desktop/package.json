{
  "name": "@gridstage/desktop",
  "version": "0.4.0",
  "private": true,
  "description": "GridStage desktop shell (Electron) — wraps the web app into an installable app",
  "license": "MIT",
  "main": "main.cjs",
  "scripts": {
    "renderer": "pnpm --filter @gridstage/web build && node copy-renderer.mjs",
    "start": "pnpm renderer && electron .",
    "dist": "pnpm renderer && electron-builder"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "org.gridstage.editor",
    "productName": "GridStage",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.cjs",
      "renderer/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        "pkg"
      ],
      "identity": null,
      "category": "public.app-category.productivity"
    },
    "publish": {
      "provider": "github",
      "owner": "ChangShengHsun",
      "repo": "GridStage",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
